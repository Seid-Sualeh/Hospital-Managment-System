{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [".env.production"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"],
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}